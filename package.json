{
  "name": "opticsLab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "check": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "release": "npm version patch && git push && git push --tags",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "generate-svg-icon": "tsx scripts/opticsToSVG.ts",
    "icons": "npm run generate-svg-icon && tsx scripts/generate-icons.ts",
    "prepare": "git config core.hooksPath .githooks",
    "commit:skip": "git commit --no-verify",
    "push:skip": "git push --no-verify"
  },
  "dependencies": {
    "scenerystack": "^3.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "canvas": "^3.2.3",
    "happy-dom": "^20.8.9",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "brace-expansion": "^5.0.5"
  }
}
